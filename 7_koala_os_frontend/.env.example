# Koala OS Frontend — Environment Variables
# Copy this file to .env.local and fill in your values

# WebSocket URL for AHIN telemetry stream (default: ws://localhost:9000)
VITE_WS_URL=wss://telemetry.ahin.io/stream

# Solana RPC endpoint (default: Solana mainnet-beta public RPC)
VITE_RPC_ENDPOINT=https://api.mainnet-beta.solana.com
