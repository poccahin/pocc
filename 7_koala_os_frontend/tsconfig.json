{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "ES2021.Intl",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.tsx",
    "src/**/*.ts",
    "components/**/*.tsx",
    "routes/**/*.tsx",
    "routes/**/*.ts",
    "hooks/**/*.ts",
    "types/**/*.d.ts",
    "workers/**/*.ts",
    "vite.config.ts"
  ]
}
