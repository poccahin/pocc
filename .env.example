# =====================================================================
# LIFE++ PLANETARY CORE - ENVIRONMENT TEMPLATE
# =====================================================================
# ⚠️ WARNING: DO NOT put real private keys here. 
# Copy this file to `.env` and fill in your local values.

# --- [L1] AHIN Gateway Settings ---
RUST_LOG=info,ahin_router=debug
AHIN_BIND_PORT=8000
WS_BROADCAST_PORT=9000

# --- [L2.5] PoCC Tensor Wind Tunnel ---
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:512
POISON_DRIFT_THRESHOLD=0.05

# --- [L3] Solana Agent Bank RPC Pool (Helius / Alchemy) ---
# Provide at least 2 for High-Availability Round-Robin Fallback
SOLANA_MAINNET_RPC_1=https://mainnet.helius-rpc.com/?api-key=INSERT_YOUR_KEY_HERE
SOLANA_MAINNET_RPC_2=https://solana-mainnet.g.alchemy.com/v2/INSERT_YOUR_KEY_HERE

# --- [L4] AP2 Cross-Chain Identity (Ethereum ERC-8004) ---
ETH_INFURA_URL=https://mainnet.infura.io/v3/INSERT_YOUR_PROJECT_ID

# --- [SECURITY] Admin Wallet Paths (Local Paths Only, NO RAW KEYS) ---
# Point to the physical location of your keypair on your secure server
ORCHESTRATOR_WALLET_PATH=/var/secure/keys/lifeplus_admin_id.json
